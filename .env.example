# Environment Variables for AI Assistant
# Copy this file to .env.local and add your actual API key

# Google Gemini API Key - Get from https://makersuite.google.com/app/apikey
# Note: This is optional - the app will work with mock responses without it
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Customize the AI model (defaults to Gemini 2.5 Flash)
# Available models: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
VITE_GEMINI_MODEL=gemini-2.5-flash